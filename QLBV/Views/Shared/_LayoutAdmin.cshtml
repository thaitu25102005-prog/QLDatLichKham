
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Quản Lý Bệnh Viện Tâm Anh</title>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@200;300;400;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        * {
            font-family: 'Nunito', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        body {
            background-color: #f8f9fc;
        }

        .sidebar {
            min-height: 100vh;
            background: linear-gradient(180deg, #4e73df 10%, #224abe 100%);
            box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.15);
        }

            .sidebar .nav-item .nav-link {
                color: rgba(255, 255, 255, 0.8);
                padding: 1rem;
                border-radius: 0.35rem;
                transition: all 0.2s;
            }

                .sidebar .nav-item .nav-link:hover,
                .sidebar .nav-item .nav-link.active {
                    color: #fff;
                    background-color: rgba(255, 255, 255, 0.1);
                }

                .sidebar .nav-item .nav-link i {
                    margin-right: 0.5rem;
                    width: 20px;
                }

        .sidebar-brand {
            padding: 1.5rem;
            text-align: center;
            color: white;
            font-weight: 700;
            font-size: 1.2rem;
        }

        .card {
            border: none;
            border-radius: 0.35rem;
            box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.15);
            margin-bottom: 1.5rem;
        }

        .card-header {
            background-color: #f8f9fc;
            border-bottom: 1px solid #e3e6f0;
            font-weight: 700;
            color: #4e73df;
        }

        .stat-card {
            border-left: 4px solid;
            transition: transform 0.2s;
            cursor: pointer;
        }

            .stat-card:hover {
                transform: translateY(-5px);
            }

            .stat-card.primary {
                border-left-color: #4e73df;
            }

            .stat-card.success {
                border-left-color: #1cc88a;
            }

            .stat-card.info {
                border-left-color: #36b9cc;
            }

            .stat-card.warning {
                border-left-color: #f6c23e;
            }

            .stat-card.danger {
                border-left-color: #e74a3b;
            }

        .stat-icon {
            font-size: 2rem;
            color: #dddfeb;
        }

        .topbar {
            background-color: white;
            box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.15);
            padding: 1rem 1.5rem;
            margin-bottom: 1.5rem;
        }

        .badge-status {
            padding: 0.35em 0.65em;
            font-size: 0.75rem;
            font-weight: 700;
        }

        .table-hover tbody tr:hover {
            background-color: #f8f9fc;
        }

        .btn-circle {
            border-radius: 50%;
            width: 35px;
            height: 35px;
            padding: 0;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .progress-sm {
            height: 0.5rem;
        }

        .chart-container {
            position: relative;
            height: 300px;
        }

        @@media (max-width: 768px) {
            .sidebar {
                position: fixed;
                left: -250px;
                width: 250px;
                z-index: 1000;
                transition: left 0.3s;
            }

                .sidebar.show {
                    left: 0;
                }
        }
    </style>
</head>
<body>

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-3 col-lg-2 px-0 sidebar">
                <div class="sidebar-brand">
                    <i class="fa-regular fa-hospital"></i>
                    Bệnh Viện Tâm Anh
                </div>

                <ul class="nav flex-column px-3">
                    <li class="nav-item">
                        <a class="nav-link active" href="~/Admin/Index" data-page="dashboard">
                            <i class="fas fa-tachometer-alt"></i>
                            <span>Tổng Quan</span>
                        </a>
                    </li>

                    <li class="nav-item mt-2">
                        <div class="text-white-50 small px-3 mb-2">QUẢN LÝ</div>
                    </li>

                   


                    <li class="nav-item">
                        <a class="nav-link collapsed" href="#collapseDonHang" data-bs-toggle="collapse" aria-expanded="false">
                            <i class="fa-solid fa-user-doctor"></i>
                            <span>Bác Sĩ</span>
                        </a>
                        <div id="collapseDonHang" class="collapse">
                            <div class="bg-white py-2 rounded ms-3">
                                <a class="nav-link text-dark small" href="@Url.Action("LoadBacSi", "Admin")">Xem Danh Sách Bác Sĩ</a>
                            </div>
                        </div>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#collapseThanhToan" data-bs-toggle="collapse" aria-expanded="false">
                            <i class="fa-solid fa-briefcase-medical"></i>
                            <span>Dịch Vụ</span>
                        </a>
                        <div id="collapseThanhToan" class="collapse">
                            <div class="bg-white py-2 rounded ms-3">
                                <a class="nav-link text-dark small" href="@Url.Action("LoadDichVu", "Admin")">Xem Danh Sách Dịch Vụ</a>
                            </div>
                        </div>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("QuanLyHoaDon", "Admin")">
                            <i class="fa-solid fa-file-invoice-dollar"></i>
                            <span>Thu Ngân / Hoá Đơn</span>
                        </a>
                    </li>
                </ul>

                <div class="px-3 mt-3 pb-3">
                    <a href="@Url.Action("Logout", "Login")" class="btn btn-outline-light w-100">
                        <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                    </a>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-md-9 col-lg-10">
                <!-- Topbar -->
                <div class="topbar d-flex justify-content-between align-items-center">
                    <div>
                        <button class="btn btn-link d-md-none" id="sidebarToggle">
                            <i class="fas fa-bars"></i>
                        </button>
                        <span class="h5 mb-0">Xin chào, <strong>Admin</strong></span>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <a href="@Url.Action("Logout", "Login")" class="btn btn-sm btn-outline-danger">
                            <i class="fas fa-sign-out-alt me-1"></i>Đăng xuất
                        </a>
                        <img src="https://ui-avatars.com/api/?name=Admin&background=4e73df&color=fff"
                             class="rounded-circle" width="40" height="40" alt="Admin">
                    </div>
                </div>
                <main>
                    @RenderBody()
                </main>

            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>

    <script>
        // Sidebar toggle for mobile
        document.getElementById('sidebarToggle')?.addEventListener('click', function () {
            document.querySelector('.sidebar').classList.toggle('show');
        });

        // Navigation handling
        document.querySelectorAll('.sidebar .nav-link').forEach(link => {
            link.addEventListener('click', function (e) {
                if (this.getAttribute('href') === '#' || this.hasAttribute('data-bs-toggle')) {
                    e.preventDefault();
                }
                document.querySelectorAll('.sidebar .nav-link').forEach(l => l.classList.remove('active'));
                this.classList.add('active');
            });
        });

        //Chart
        document.addEventListener("DOMContentLoaded", function () {
        fetch('@Url.Action("BieuDoDoanhThuThang", "DashBoard")')
            .then(res => res.json())
            .then(data => {
                const ctx = document.getElementById('revenueChart');
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: ['T1', 'T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'T8', 'T9', 'T10', 'T11', 'T12'],
                        datasets: [{
                            label: 'Doanh Thu',
                            data: data,
                            borderColor: '#4e73df',
                            backgroundColor: 'rgba(78, 115, 223, 0.1)',
                            borderWidth: 3,
                            fill: true,
                            tension: 0.4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        return 'Doanh thu: ' + context.parsed.y.toLocaleString('vi-VN') + ' ₫';
                                    }
                                }
                            }
                        },
                        scales: {
                            yAxes: [{
                                ticks: {
                                    beginAtZero: true,
                                    callback: function (value) {
                                        return (value / 1000000).toFixed(0) + 'M ₫';
                                    }
                                }
                            }]
                        }
                    }
                });
            });
    });


    // Auto-refresh notifications (demo)
    setInterval(() => {
    const badge = document.querySelector('.badge.bg-danger');
    if (badge) {
    const currentCount = parseInt(badge.textContent);
    if (currentCount < 10) {
    badge.textContent = currentCount + 1;
    }
    }
    }, 30000); // Every 30 seconds

    // Alert for low stock items
    console.log('Dashboard loaded successfully with Vietnamese support');
    </script>

</body>
</html>