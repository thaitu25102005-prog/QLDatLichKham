@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Đăng nhập</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg, #0062E6 0%, #33AEFF 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .login-card {
            background: white;
            border-radius: 16px;
            padding: 36px 32px 28px;
            width: 420px;
            box-shadow: 0 12px 40px rgba(0,0,0,0.25);
        }
        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: #003A91;
            font-size: 13px;
            text-decoration: none;
            margin-bottom: 18px;
            opacity: 0.8;
            transition: opacity 0.2s;
        }
        .back-link:hover { opacity: 1; color: #003A91; }
        .login-card h2 {
            text-align: center;
            margin-bottom: 24px;
            font-weight: 700;
            color: #003A91;
            font-size: 22px;
        }
        .btn-login {
            background: linear-gradient(135deg, #003A91, #0056d6);
            color: white;
            font-weight: bold;
            border: none;
            padding: 10px;
            transition: opacity 0.2s;
        }
        .btn-login:hover { opacity: 0.88; color: white; }
        .error-msg { color: #dc3545; text-align: center; margin-bottom: 12px; font-size: 14px; }
        .home-footer {
            text-align: center;
            margin-top: 18px;
            padding-top: 14px;
            border-top: 1px solid #eee;
        }
        .home-footer a {
            color: #777;
            font-size: 13px;
            text-decoration: none;
            transition: color 0.2s;
        }
        .home-footer a:hover { color: #003A91; }
    </style>
</head>
<body>

    <div class="login-card">

        @* Nút về trang chủ *@
        <a href="@Url.Action("Index", "Home")" class="back-link">
            <i class="fas fa-arrow-left"></i> Về trang chủ
        </a>

        <h2>ĐĂNG NHẬP</h2>

        @if (ViewBag.Error != null)
        {
            <p class="error-msg"><i class="fas fa-exclamation-circle me-1"></i>@ViewBag.Error</p>
        }

        <form method="post">
            <div class="mb-3">
                <label for="name" class="form-label fw-semibold">Tên đăng nhập</label>
                <input type="text" class="form-control" id="name" name="name"
                       placeholder="Admin hoặc Mã bác sĩ (VD: BS001)" required />
            </div>
            <div class="mb-3">
                <label for="pass" class="form-label fw-semibold">Mật khẩu</label>
                <input type="password" class="form-control" id="pass" name="pass"
                       placeholder="Nhập mật khẩu" required />
            </div>
            <button type="submit" class="btn btn-login w-100">
                <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập
            </button>
        </form>

        <div class="home-footer">
            <a href="@Url.Action("Index", "Home")">
                <i class="fas fa-home me-1"></i> Quay về trang chủ bệnh viện
            </a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>