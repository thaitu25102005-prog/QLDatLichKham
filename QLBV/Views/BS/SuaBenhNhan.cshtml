@model QLBV.Models.BENHNHAN
@{
    Layout = "~/Views/Shared/_LayoutBacSi.cshtml";
}

<h2>@ViewBag.Title</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.BNHAN_ID)

    <div class="mb-3">
        @Html.LabelFor(m => m.HOTENBENHNHAN)
        @Html.TextBoxFor(m => m.HOTENBENHNHAN, new { @class = "form-control" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.CCCD)
        @Html.TextBoxFor(m => m.CCCD, new { @class = "form-control", @readonly = "readonly" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.SDT)
        @Html.TextBoxFor(m => m.SDT, new { @class = "form-control" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.GIOITINH)
        @Html.DropDownListFor(m => m.GIOITINH, new SelectList(new[] { "Nam", "Nữ" }), "Chọn giới tính", new { @class = "form-control" })
    </div>

    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
    <a href="@Url.Action("DanhSachBenhNhan", "BS")" class="btn btn-secondary">Hủy</a>
}
