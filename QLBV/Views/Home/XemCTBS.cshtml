
@model QLBV.Models.BACSI

@{
    ViewBag.Title = "Chi tiết bác sĩ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="row">

        <!-- ẢNH BÁC SĨ -->
        <div class="col-md-4">
            <img src="@Model.AVATAR" class="img-fluid shadow rounded" style="border-radius:12px;" />
        </div>

        <!-- THÔNG TIN  -->
        <div class="col-md-4">
            <div class="p-3 shadow-sm" style="border-radius:10px; background:#f8f9fa;">
                <h2 class="fw-bold">@Model.TENBACSI</h2>
                <p><b>Học vị:</b> @Model.HOCVI</p>
                <p><b>Học hàm:</b> @Model.HOCHAM</p>
                <p><b>Chức vụ:</b> @Model.CHUCVU</p>
                <p><b>Số bệnh nhân đang khám:</b> @Model.SOBN</p>
                <p><b>Khoa:</b> @Model.KHOA.TENKHOA</p>

                <a href="@Url.Action("ChuyenGia", "Home")" class="btn btn-secondary mt-2 w-100">
                    ⬅ Quay lại danh sách
                </a>
            </div>
        </div>

        <!-- CỘT 3: FORM ĐĂNG KÝ -->
        <div class="col-md-4">
            <div class="card shadow" style="border-radius:12px;">
                <div class="card-header text-white" style="background:#003A91;border-radius:12px 12px 0 0;">
                    <h4 class="mb-0 text-center">ĐĂNG KÝ KHÁM BỆNH</h4>
                </div>

                <div class="card-body">

                    <label class="fw-bold">CCCD</label>
                    <input type="text" id="txtCCCD" class="form-control" maxlength="12"
                           placeholder="Nhập 12 số CCCD" />

                    <label class="mt-3 fw-bold">Họ và tên</label>
                    <input type="text" id="txtHoTen" class="form-control" placeholder="Nhập họ tên (nếu mới)" />

                    <label class="mt-3 fw-bold">Số điện thoại</label>
                    <input type="text" id="txtSDT" class="form-control" placeholder="Nhập số điện thoại" />

                    <label class="mt-3 fw-bold">Giới tính</label>
                    <select id="cboGioiTinh" class="form-control">
                        <option value="Nam">Nam</option>
                        <option value="Nữ">Nữ</option>
                    </select>

                    <label class="mt-3 fw-bold">Bác sĩ</label>
                    <select id="cboBacSi" class="form-control">
                        <option value="@Model.BACSI_ID">@Model.TENBACSI</option>
                    </select>

                    <label class="mt-3 fw-bold">Ca khám</label>
                    <select id="cboCaKham" class="form-control">
                        <option value="1">08:00</option>
                        <option value="2">08:30</option>
                        <option value="3">09:00</option>
                        <option value="4">09:30</option>
                        <option value="5">13:00</option>
                        <option value="6">13:30</option>
                        <option value="7">14:00</option>
                        <option value="8">14:30</option>
                    </select>

                    <label class="mt-3 fw-bold">Ngày khám</label>
                    <input type="date" id="ngayKham" class="form-control" min="@DateTime.Now.ToString("yyyy-MM-dd")" />

                    <button class="btn btn-warning w-100 mt-4 fw-bold" id="btnDangKy">
                        Đăng ký khám
                    </button>

                </div>
            </div>
        </div>

    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script>


    // Đăng ký lịch khám
    $("#btnDangKy").click(function () {
        var mabacsi = $("#cboBacSi").val();
        var ngaykham = $("#ngayKham").val();
        var cakhams = parseInt($("#cboCaKham").val());
        var cccd = $("#txtCCCD").val().trim();
        var hoten = $("#txtHoTen").val().trim();
        var sdt = $("#txtSDT").val().trim();
        var gioitinh = $("#cboGioiTinh").val();

        if (!mabacsi || !ngaykham || !cakhams || !cccd || !hoten || !sdt) {
            alert("Vui lòng điền đầy đủ thông tin!");
            return;
        }

        if (!/^\d{12}$/.test(cccd)) {
            alert("CCCD phải đủ 12 chữ số!");
            return;
        }

        $.post("/Home/DatLichKham",
            { mabacsi, ngaykham, cakhams, cccd, hoten, sdt, gioitinh },
            function (res) {
                alert(res.message);
            }
        );
    });



</script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
