@model List<QLBV.Models.FN_XuatKetQuaDaKham_TheoBN_Result>

@{
    ViewBag.Title = "Kết quả khám";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Kết quả khám</h2>

@if (ViewBag.KetQuaCount == 0)
{
    <div class="alert alert-warning">Không tìm thấy kết quả nào!</div>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Mã KQ</th>
                <th>Họ tên</th>
                <th>SDT</th>
                <th>Chuẩn đoán</th>
                <th>Kết luận</th>
                <th>Thành viên</th>
                <th>Ghi chú</th>
                <th>Ngày khám</th>
                <th>Bác sĩ chuẩn trị</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.MAKQ</td>
                    <td>@item.HOTENBENHNHAN</td>
                    <td>@item.SDT</td>
                    <td>@item.CHUANDOAN</td>
                    <td>@item.KETLUAN</td>
                    <td>@item.THANHVIEN</td>
                    <td>@item.GHICHU</td>
                    <td>@item.NGAYKHAM</td>
                    <td>@item.TENBACSI</td>
                </tr>
            }
        </tbody>
    </table>

}
