@model IEnumerable<QLBV.Models.DICHVU>

@{
    ViewBag.Title = "LoadDichVu";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}


<p>
    @Html.ActionLink("Thêm dịch vụ mới", "CreateDV")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.DV_ID)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.MADV)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.TENDV)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.DONGIA)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.GHICHU)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.KHOA_ID)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.DV_ID)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.MADV)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.TENDV)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.DONGIA)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.GHICHU)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.KHOA_ID)
        </td>
        <td>
            @Html.ActionLink("Sửa thông tin dịch vụ", "EditDV", new { id = item.MADV }) |
            @*@Html.ActionLink("Details", "Details", new { /* id=item.PrimaryKey */ }) |*@
            @Html.ActionLink("Xóa dịch vụ", "DeleteDV", new { id = item.MADV })
        </td>
    </tr>
}

</table>
